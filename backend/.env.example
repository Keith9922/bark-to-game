# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Which generator backend to use:
#   "api" — direct Anthropic Messages API call to the configured proxy (recommended)
#   "sdk" — claude-agent-sdk subprocess (shares your Claude Max plan auth)
BARK_GENERATOR_MODE=api

# Anthropic Messages API proxy. Aipaibox is one option that supports
# Claude models via Anthropic-compatible /v1/messages.
BARK_API_BASE_URL=https://api.aipaibox.com

# Your API key for the proxy above. REQUIRED when BARK_GENERATOR_MODE=api.
BARK_API_KEY=sk-replace-me

# Model. Defaults to the latest Opus, best for code-output-dense game gen.
# Other options seen on aipaibox: claude-opus-4-7-thinking, claude-opus-4-6,
# claude-opus-4-6-thinking, claude-sonnet-4-6.
BARK_API_MODEL=claude-opus-4-7

# Upper bound on tokens per generation. Single-file games fit comfortably.
BARK_API_MAX_OUTPUT_TOKENS=16000

# Model for the translate stage (tokens -> 5 game-concept candidates).
# Lighter task, defaults to Sonnet for cost. Set to Opus if Sonnet's concepts
# feel uninspired in your demos.
BARK_API_TRANSLATE_MODEL=claude-sonnet-4-6
BARK_API_TRANSLATE_MAX_OUTPUT_TOKENS=4096
